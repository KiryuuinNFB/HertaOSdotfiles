{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing" : 0,

  "modules-left": [
  "custom/arch",
  "hyprland/workspaces",
  "custom/btop"
  ],

  "modules-center": ["clock"],

  "modules-right": [
    "network",
    "tray",
    "hyprland/language",
    "backlight",
    "battery",
    "pulseaudio"
  ],

  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "hyprland/language": {
        "format": "{}",
        "format-en": "EN",
        "format-th": "TH"
    },

  "bluetooth": {
    "format": "≤░Γ▓",
    "format-on": "{icon}",
    "format-off": "{icon}", 
    "format-connected":"{icon}",
    "format-icons":{
        "on":"≤░Γψ",
        "off": "≤░Γ▓",
        "connected": "≤░Γ▒",
        },
    "on-click": "blueman-manager",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "clock": {
    "timezone": "Asia/Bangkok",
    "tooltip": false,
    "format": "{:%H:%M:%S  έΑλ  %d %B %Y}",
    "interval": 1
  },

  "network": {
    "format-wifi": "≤░νλ",
    "format-ethernet": "≤░ΙΑ ",
    "format-disconnected": "≤░νι ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "kitty -e nmtui"

 },


  "custom/uptime": {
    "format": "{}",
    "format-icon": ["ΎΒλ"], 
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/.config/waybar/scripts/uptime.sh"
  },
  
  "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["ΌΟΞ","≤░Δε", "≤░Δδ", "≤░Δη","≤░Δζ","≤░Δθ","≤░Δι"],
        "tooltip": false
  },
  
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "ΎΣο ",
    "format-icons": {
      "default": ["ΎΑο ", "ΎΑπ ", "ΎΑρ  "]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
        "interval":2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "on-click": "wattage",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  
  
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": true,
        "tooltip-format": "Herta OS Control Center",
        "on-click": "swaync-client -t",
  },

  "custom/btop": {
      "format": "ΎΜδ",
      "on-click" : "kitty -e btop"
    },
}


}